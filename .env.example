# Supabase público — usado pelo navegador
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_EXEMPLO

# Supabase administrativo — somente no servidor/Vercel
SUPABASE_SERVICE_ROLE_KEY=sb_secret_EXEMPLO

# URL pública de produção, sem barra no final
NEXT_PUBLIC_APP_URL=https://seu-projeto.vercel.app

# Chave aleatória Base64 de 32 bytes para cifrar credenciais administrativas
DRIVE_SETTINGS_ENCRYPTION_KEY=COLE_AQUI_A_CHAVE_GERADA
